name: CI/CD Monorepo Pipeline

on:
  push:
    branches:
      - main

# Cancel in-progress runs on new pushes to the same branch
concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

env:
  REGISTRY_GHCR: ghcr.io
  REGISTRY_DOCKERHUB: docker.io
  IMAGE_PREFIX: ${{ github.repository_owner }}

# ─────────────────────────────────────────────
# STAGE 0 – Detect which services changed
# ─────────────────────────────────────────────
jobs:
  detect-changes:
    name: 🔍 Detect Changed Services
    runs-on: ubuntu-latest
    outputs:
      node:    ${{ steps.filter.outputs.node }}
      python:  ${{ steps.filter.outputs.python }}
      rust:    ${{ steps.filter.outputs.rust }}
      go:      ${{ steps.filter.outputs.go }}
      docker:  ${{ steps.filter.outputs.docker }}
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 2   # needed for dorny/paths-filter

      - name: Detect path changes
        id: filter
        uses: dorny/paths-filter@v3
        with:
          filters: |
            node:
              - 'services/node-app/**'
              - '.github/workflows/ci-cd.yml'
            python:
              - 'services/python-app/**'
              - '.github/workflows/ci-cd.yml'
            rust:
              - 'services/rust-app/**'
              - '.github/workflows/ci-cd.yml'
            go:
              - 'services/go-app/**'
              - '.github/workflows/ci-cd.yml'
            docker:
              - '**/Dockerfile'
              - '**/.dockerignore'
              - 'docker-compose*.yml'

# ─────────────────────────────────────────────
# STAGE 1 – Lint, Test & Build (per service)
# ─────────────────────────────────────────────

  # ── Node.js ──────────────────────────────
  node-ci:
    name: 🟩 Node.js — Lint / Test / Build
    needs: detect-changes
    if: needs.detect-changes.outputs.node == 'true'
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: services/node-app

    steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
          cache-dependency-path: services/node-app/package-lock.json

      - name: Install dependencies
        run: npm ci

      - name: Lint
        run: npm run lint

      - name: Type-check
        run: npm run typecheck
        continue-on-error: false

      - name: Unit tests
        run: npm run test -- --coverage --reporter=json --outputFile=test-results.json

      - name: Build
        run: npm run build

      - name: Upload Node build artifact
        uses: actions/upload-artifact@v4
        with:
          name: node-build
          path: services/node-app/dist/
          retention-days: 7

      - name: Upload test results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: node-test-results
          path: services/node-app/test-results.json
          retention-days: 7

  # ── Python ───────────────────────────────
  python-ci:
    name: 🐍 Python — Lint / Test / Build
    needs: detect-changes
    if: needs.detect-changes.outputs.python == 'true'
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: services/python-app

    steps:
      - uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'
          cache: 'pip'
          cache-dependency-path: services/python-app/requirements*.txt

      - name: Install dependencies
        run: |
          pip install --upgrade pip
          pip install -r requirements.txt
          pip install -r requirements-dev.txt

      - name: Lint (ruff)
        run: ruff check .

      - name: Format check (black)
        run: black --check .

      - name: Type-check (mypy)
        run: mypy .

      - name: Unit tests (pytest)
        run: |
          pytest --junitxml=test-results.xml \
                 --cov=. \
                 --cov-report=xml:coverage.xml \
                 -v

      - name: Build wheel
        run: |
          pip install build
          python -m build --outdir dist/

      - name: Upload Python build artifact
        uses: actions/upload-artifact@v4
        with:
          name: python-build
          path: services/python-app/dist/
          retention-days: 7

      - name: Upload test results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: python-test-results
          path: |
            services/python-app/test-results.xml
            services/python-app/coverage.xml
          retention-days: 7

  # ── Rust ─────────────────────────────────
  rust-ci:
    name: 🦀 Rust — Lint / Test / Build
    needs: detect-changes
    if: needs.detect-changes.outputs.rust == 'true'
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: services/rust-app

    steps:
      - uses: actions/checkout@v4

      - name: Setup Rust toolchain
        uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy

      - name: Cache Cargo registry & build
        uses: Swatinem/rust-cache@v2
        with:
          workspaces: services/rust-app

      - name: Lint (clippy)
        run: cargo clippy --all-targets --all-features -- -D warnings

      - name: Format check
        run: cargo fmt --all -- --check

      - name: Run tests
        run: cargo test --all-features -- --test-threads=4

      - name: Build release binary
        run: cargo build --release --locked

      - name: Upload Rust binary artifact
        uses: actions/upload-artifact@v4
        with:
          name: rust-binary
          path: services/rust-app/target/release/rust-app
          retention-days: 7

  # ── Go ───────────────────────────────────
  go-ci:
    name: 🐹 Go — Lint / Test / Build
    needs: detect-changes
    if: needs.detect-changes.outputs.go == 'true'
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: services/go-app

    steps:
      - uses: actions/checkout@v4

      - name: Setup Go
        uses: actions/setup-go@v5
        with:
          go-version: '1.22'
          cache-dependency-path: services/go-app/go.sum

      - name: Download modules
        run: go mod download

      - name: Lint (golangci-lint)
        uses: golangci/golangci-lint-action@v6
        with:
          version: latest
          working-directory: services/go-app

      - name: Vet
        run: go vet ./...

      - name: Run tests
        run: go test -race -coverprofile=coverage.out ./...

      - name: Build binary
        run: |
          CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
          go build -ldflags="-s -w" -o dist/go-app ./cmd/...

      - name: Upload Go binary artifact
        uses: actions/upload-artifact@v4
        with:
          name: go-binary
          path: services/go-app/dist/go-app
          retention-days: 7

      - name: Upload coverage
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: go-coverage
          path: services/go-app/coverage.out
          retention-days: 7

# ─────────────────────────────────────────────
# STAGE 2 – Docker Build & Publish
# ─────────────────────────────────────────────
  docker-publish:
    name: 🐳 Docker — Build & Push (${{ matrix.service }})
    needs:
      - detect-changes
      - node-ci
      - python-ci
      - rust-ci
      - go-ci
    # Run if any service CI passed OR a Dockerfile itself changed.
    # `always()` lets us check needs status ourselves.
    if: |
      always() &&
      !contains(needs.*.result, 'failure') &&
      !contains(needs.*.result, 'cancelled')
    runs-on: ubuntu-latest

    strategy:
      fail-fast: false
      matrix:
        include:
          - service: node-app
            context: services/node-app
            image: node-app
            changed: ${{ needs.detect-changes.outputs.node }}
          - service: python-app
            context: services/python-app
            image: python-app
            changed: ${{ needs.detect-changes.outputs.python }}
          - service: rust-app
            context: services/rust-app
            image: rust-app
            changed: ${{ needs.detect-changes.outputs.rust }}
          - service: go-app
            context: services/go-app
            image: go-app
            changed: ${{ needs.detect-changes.outputs.go }}

    steps:
      - name: Skip unchanged service
        if: matrix.changed != 'true' && needs.detect-changes.outputs.docker != 'true'
        run: |
          echo "⏭  No changes detected for ${{ matrix.service }}, skipping Docker build."
          exit 0

      - uses: actions/checkout@v4

      # Download the build artifact produced in Stage 1 (if any)
      - name: Download build artifact
        uses: actions/download-artifact@v4
        with:
          # Map matrix service → artifact name produced above
          name: ${{ matrix.image == 'node-app' && 'node-build'
                  || matrix.image == 'python-app' && 'python-build'
                  || matrix.image == 'rust-app' && 'rust-binary'
                  || 'go-binary' }}
          path: ${{ matrix.context }}/artifact/
        continue-on-error: true   # artifact may not exist if service was skipped

      - name: Set up QEMU (multi-arch)
        uses: docker/setup-qemu-action@v3

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to Docker Hub
        uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY_DOCKERHUB }}
          username: ${{ secrets.DOCKERHUB_USERNAME }}
          password: ${{ secrets.DOCKERHUB_TOKEN }}

      - name: Log in to GitHub Container Registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY_GHCR }}
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Extract Docker metadata (tags & labels)
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: |
            ${{ env.REGISTRY_DOCKERHUB }}/${{ env.IMAGE_PREFIX }}/${{ matrix.image }}
            ${{ env.REGISTRY_GHCR }}/${{ github.repository_owner }}/${{ matrix.image }}
          tags: |
            type=sha,prefix=sha-,format=short
            type=raw,value=latest,enable={{is_default_branch}}
            type=raw,value=main-{{date 'YYYYMMDD'}}-{{sha}}

      - name: Build & push Docker image
        uses: docker/build-push-action@v6
        with:
          context: ${{ matrix.context }}
          file: ${{ matrix.context }}/Dockerfile
          platforms: linux/amd64,linux/arm64
          push: true
          tags: ${{ steps.meta.outputs.tags }}
          labels: ${{ steps.meta.outputs.labels }}
          cache-from: type=gha,scope=${{ matrix.service }}
          cache-to:   type=gha,scope=${{ matrix.service }},mode=max
          build-args: |
            BUILD_DATE=${{ github.event.head_commit.timestamp }}
            VCS_REF=${{ github.sha }}
            VERSION=${{ github.ref_name }}

      - name: Export image digest
        run: |
          echo "### 🐳 Docker Image Published" >> $GITHUB_STEP_SUMMARY
          echo "| Registry | Image | Tags |" >> $GITHUB_STEP_SUMMARY
          echo "|----------|-------|------|" >> $GITHUB_STEP_SUMMARY
          echo "| Docker Hub | \`${{ env.IMAGE_PREFIX }}/${{ matrix.image }}\` | \`${{ steps.meta.outputs.tags }}\` |" >> $GITHUB_STEP_SUMMARY
          echo "| GHCR | \`${{ github.repository_owner }}/${{ matrix.image }}\` | \`${{ steps.meta.outputs.tags }}\` |" >> $GITHUB_STEP_SUMMARY

# ─────────────────────────────────────────────
# STAGE 3 – Publish consolidated artifact bundle
# ─────────────────────────────────────────────
  publish-artifacts:
    name: 📦 Publish Artifact Bundle
    needs:
      - node-ci
      - python-ci
      - rust-ci
      - go-ci
      - docker-publish
    if: |
      always() &&
      !contains(needs.*.result, 'failure') &&
      !contains(needs.*.result, 'cancelled')
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Download all build artifacts
        uses: actions/download-artifact@v4
        with:
          path: all-artifacts/
          # Downloads every artifact uploaded in this run into sub-folders
          merge-multiple: false

      - name: List downloaded artifacts
        run: find all-artifacts/ -type f | sort

      - name: Create release archive
        run: |
          VERSION="main-$(date +%Y%m%d)-${GITHUB_SHA::8}"
          tar -czf "release-${VERSION}.tar.gz" -C all-artifacts .
          echo "ARCHIVE=release-${VERSION}.tar.gz" >> $GITHUB_ENV
          echo "VERSION=${VERSION}" >> $GITHUB_ENV

      - name: Upload consolidated release archive
        uses: actions/upload-artifact@v4
        with:
          name: release-bundle-${{ env.VERSION }}
          path: ${{ env.ARCHIVE }}
          retention-days: 30

      - name: Write job summary
        run: |
          echo "## ✅ CI/CD Pipeline Complete" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "| Service   | Status |" >> $GITHUB_STEP_SUMMARY
          echo "|-----------|--------|" >> $GITHUB_STEP_SUMMARY
          echo "| 🟩 Node.js   | ${{ needs.node-ci.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| 🐍 Python    | ${{ needs.python-ci.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| 🦀 Rust      | ${{ needs.rust-ci.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| 🐹 Go        | ${{ needs.go-ci.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| 🐳 Docker    | ${{ needs.docker-publish.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "**Release archive:** \`${{ env.ARCHIVE }}\`" >> $GITHUB_STEP_SUMMARY
          echo "**Commit:** \`${{ github.sha }}\`" >> $GITHUB_STEP_SUMMARY
          echo "**Triggered by:** @${{ github.actor }}" >> $GITHUB_STEP_SUMMARY